{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/notion-pull", "dest": "/api/notion-pull.js" },
    { "src": "/api/notion-push", "dest": "/api/notion-push.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
